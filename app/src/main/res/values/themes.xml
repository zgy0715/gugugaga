<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 默认应用主题：无 ActionBar，Material 配色保留给可能的通知/设置页 -->
    <style name="Theme.Gugugaga" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════
         完全无窗口主题

         继承自 @android:style/Theme.NoDisplay（Android 原生主题），
         系统层面跳过窗口创建，Activity 不获取任何窗口资源。

         只在 Activity 继承自 Activity（而非 AppCompatActivity）时有效。
         ═══════════════════════════════════════════════════════════════ -->
    <style name="Theme.Gugugaga.NoDisplay" parent="@android:style/Theme.NoDisplay">
        <!-- 不在最近任务列表显示 -->
        <item name="android:excludeFromRecents">true</item>
    </style>
</resources>
